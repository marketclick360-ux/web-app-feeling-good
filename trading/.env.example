# Copy this file to .env and fill in your values
# .env is gitignored — never commit the real file

# From https://developer.schwab.com → Your Apps → [app name] → View Details
SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here

# Must match the Callback URL you set when creating the app.
# Schwab requires HTTPS. For local use, set it to: https://127.0.0.1
SCHWAB_CALLBACK_URL=https://127.0.0.1

# Your account size in dollars (used for position sizing)
# Leave blank to auto-read from your live Schwab account balance
ACCOUNT_SIZE=1673.00
